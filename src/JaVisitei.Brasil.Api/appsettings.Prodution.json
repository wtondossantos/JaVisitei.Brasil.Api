{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Connection": {
    "Base": "${{ secrets.API_CONNECTION }}"
  },
  "JWT": {
    "JWT_AUDIENCE": "${{ secrets.JWT_AUDIENCE }}",
    "JWT_ISSUER": "${{ secrets.JWT_ISSUER }}",
    "JWT_KEY": "${{ secrets.JWT_KEY }}",
    "JWT_SUBJECT": "${{ secrets.JWT_SUBJECT }}"
  }
}
